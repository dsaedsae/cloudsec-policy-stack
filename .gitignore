# Python
.venv/
__pycache__/
*.pyc

# Terraform
.terraform/
*.tfstate
*.tfstate.*
crash.log
*.tfplan

# Kubeconfig / secrets (path-anchored — kind writes terraform/<cluster>-config)
kubeconfig
*.kubeconfig
**/*-config
*.pem
*.key
*-key.pem
terraform/cloudsec-config

# Runtime encryption-at-rest material: generated AES key + apiserver manifest
# backup (scripts/enable-secrets-encryption.*). NEVER commit the key.
terraform/.enc/

# MkDocs build output (the site is built by CI / mkdocs serve, not committed)
site/
.cache/

# Generated SBOMs (build provenance): regenerated by scripts/scan.* on demand.
# Each run carries a fresh serialNumber/timestamp, so they are not committed —
# the scan gate + the documented trivy command are the reproducible evidence.
outputs/sbom/*.json

# cross-layer-lint reports: regenerated by `make report` (and bundled into the
# deployed site/ by `make site`). The generator + the live text run are the
# reproducible evidence, so the rendered artifacts are not committed.
outputs/cross-layer/

# Raw packet captures (scripts/capture-wg.*): may contain node IPs; commit only the
# sanitized docs/assets/evidence/wg-capture-summary.txt, never the pcap.
docs/assets/evidence/*.pcap
